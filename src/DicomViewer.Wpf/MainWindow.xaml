<Window x:Class="DicomViewer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:nav="clr-namespace:DicomViewer.Wpf.Navigation"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="DicomViewer"
        Width="1480"
        Height="940"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#0F141A">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF1F5" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Background" Value="#243341" />
            <Setter Property="Foreground" Value="#F5FAFD" />
            <Setter Property="BorderBrush" Value="#334758" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Padding="18"
                Background="#16202A"
                BorderBrush="#263746"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="DicomViewer Shell" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="当前主窗口只负责模块导航与页面承载，查看器与曝光控制台已独立。" Foreground="#9FB0BC" Margin="0,6,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="影像查看器" Command="{Binding NavigateViewerCommand}" />
                        <Button Content="曝光控制台" Command="{Binding NavigateExposureConsoleCommand}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Padding="18,12" Background="#10171E" CornerRadius="12">
                    <StackPanel Width="320">
                        <TextBlock Text="{Binding CurrentPageTitle}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentPageDescription}" Foreground="#9FB0BC" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Margin="16" Background="#0B1015" CornerRadius="18" BorderBrush="#243341" BorderThickness="1.2">
            <ContentControl prism:RegionManager.RegionName="{x:Static nav:RegionNames.MainContentRegion}" />
        </Border>
    </DockPanel>
</Window>
